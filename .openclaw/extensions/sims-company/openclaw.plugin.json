{
  "id": "sims-company",
  "configSchema": {
    "type": "object",
    "properties": {
      "authorityUrl": {
        "type": "string",
        "description": "Authority HTTP base URL (default: http://127.0.0.1:19789)"
      },
      "companyId": {
        "type": "string",
        "description": "Default companyId for sims-company tools"
      },
      "timeoutMs": {
        "type": "number",
        "description": "Default timeout for dispatch and report authority calls"
      }
    }
  }
}
